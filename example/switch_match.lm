use "std" -> std;

act[io.out] main() -> i32 {
  val n = 2;

  switch (n) {
    1: { std.println("one"); }
    2: { std.println("two"); }
    else: { std.println("other"); }
  }

  match (n) {
    1: { std.println("match one"); }
    2: { std.println("match two"); }
    else: { std.println("match other"); }
  }

  return 0;
}
